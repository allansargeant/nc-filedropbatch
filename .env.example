# Copy this file to .env and set real values before running `docker compose up`.
# .env is gitignored - never commit real credentials.

DB_ROOT_PASSWORD=changeme
DB_PASSWORD=changeme
NEXTCLOUD_ADMIN_USER=admin
NEXTCLOUD_ADMIN_PASSWORD=changeme

# Only needed if you bring up docker-compose.site-server.yml to test the
# rclone site-sync feature against a second local instance.
SITE_DB_ROOT_PASSWORD=changeme
SITE_DB_PASSWORD=changeme
SITE_ADMIN_USER=siteadmin
SITE_ADMIN_PASSWORD=changeme
